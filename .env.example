# Sky Limit Travels - Environment Variables
# Copy this file to .env for local development
# Amadeus API Credentials
AMADEUS_CLIENT_ID=your_client_id_here

AMADEUS_CLIENT_SECRET=your_client_secret_here

POSTGRES_PRISMA_URL='file:./dev.db'

# Database Configuration
DATABASE_URL="file:./dev.db"

# Email Configuration
EMAIL_HOST="smtp.example.com"

EMAIL_PORT="587"

EMAIL_USER="your-email@example.com"

EMAIL_PASS="your-email-password"

EMAIL_FROM="website@skylimittravels.co.uk"

EMAIL_TO="Flightbookings@skylimittravels.co.uk"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"

NEXTAUTH_SECRET="03145f86fc04c986ebf1ec563f54370b3aaa01145bfd6b6935f4903017fe6c52"

# Admin Access Password (for cache management)
ADMIN_PASSWORD="Admin123"

# Cache Settings (in days)
CACHE_DURATION_DAYS=3

# API Key Secret (for internal API usage)
API_KEY_SECRET="skylimit-default-secret-key"

# Node Environment
NODE_ENV="development"
# Set to "production" for production deployment
