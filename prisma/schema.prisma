// This is your Prisma schema file for Supabase connection,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


datasource db {
  provider  = "postgresql"
  
  // url       = env("POSTGRES_PRISMA_URL") // Connection pooling URL for Supabase
  // directUrl = env("POSTGRES_URL_NON_POOLING") // Direct connection URL for migrations
}

generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["driverAdapters"]
}
// Model for storing contact form enquiries
model Enquiry {
  id            String       @id @default(uuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  message       String
  type          String       @default("GENERAL")
  flightDetails String?
  holidayDetails String?
  packageDetails String?
  status        EnquiryStatus @default(NEW)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Status of enquiries
enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
}

// Model for admin users
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User roles
enum UserRole {
  ADMIN
  STAFF
}

// Model for holidays
model Holiday {
  id          String   @id @default(uuid())
  title       String
  description String
  destination String
  duration    String
  price       Float
  imageUrl    String?
  featured    Boolean  @default(false)
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Destination {
  id                      String    @id @default(cuid())
  title                   String
  description             String    @db.Text
  destination             String
  duration                String
  price                   Float
  slogan                  String?
  discountUpTo            Float?
  featured                Boolean   @default(false)
  available               Boolean   @default(true)
  destinationImage        String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  
  landingPageDestinations LandingPageDestination[]
  landingPageTips         LandingPageTip[]

  @@map("destinations")
}

model LandingPageDestination {
  id                String      @id @default(cuid())
  from              String
  destination       String
  duration          String
  price             Float
  date              DateTime
  stops             Int         @default(1)
  destinationImage  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  destinationId     String
  destinationRef    Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("landing_page_destinations")
}

model LandingPageTip {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("landing_page_tips")
}
// Trip status enum
enum TripStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Trip Plan model for handling customer trip requests
model TripPlan {
  id            String     @id @default(uuid())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  // Trip details
  destination   String
  tripType      String     // flight, hotel, both
  departureDate DateTime
  returnDate    DateTime
  adults        Int        @default(1)
  children      Int        @default(0)
  infants       Int        @default(0)
  
  // Customer information
  customerName  String
  customerEmail String
  
  // Admin tracking fields
  status        TripStatus @default(PENDING)
  notes         String?
  assignedTo    String?    // Staff member handling this request
  
  @@index([status])
  @@index([createdAt])
} 