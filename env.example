# Database Configuration
# For local development (SQLite)
DATABASE_URL="file:./dev.db"

# For production (Supabase PostgreSQL)
# IMPORTANT: Set these in your Hostinger/deployment environment variables!
# Without these, the build will fail with "Tenant or user not found" errors

# Primary Prisma connection (with connection pooling for serverless)
POSTGRES_PRISMA_URL="postgresql://user:password@host:6543/database?pgbouncer=true&connection_limit=1"

# Non-pooling connection (for migrations and admin operations)
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database"

# Fallback database URL
DATABASE_URL="postgresql://user:password@host:5432/database"

# For vercel-db-helper.js
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL_NON_POOLING=""

# NextAuth Configuration
NEXTAUTH_SECRET="your-secure-random-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Amadeus API Configuration
AMADEUS_CLIENT_ID="your-amadeus-client-id"
AMADEUS_CLIENT_SECRET="your-amadeus-client-secret"

# Admin Configuration
ADMIN_PASSWORD="Admin123!"

# Email Configuration (Optional)
EMAIL_HOST="smtp.skylimittravels.co.uk"
EMAIL_PORT="587"
EMAIL_USER="noreply@skylimittravels.co.uk"
EMAIL_PASS="your-email-password"
EMAIL_FROM="website@skylimittravels.co.uk"
EMAIL_TO="Flightbookings@skylimittravels.co.uk"

# Cache Configuration
CACHE_DURATION_DAYS="3"

# Environment
NODE_ENV="development"

# Geonames API for country code lookup
GEONAMES_USERNAME=your_geonames_username

# Travelpayouts API
TRAVELPAYOUTS_API_TOKEN=your_travelpayouts_api_token
TRAVELPAYOUTS_MARKER=your_travelpayouts_marker 